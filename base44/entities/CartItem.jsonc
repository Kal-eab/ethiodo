{
  "name": "CartItem",
  "type": "object",
  "properties": {
    "product_id": {
      "type": "string",
      "description": "Product ID"
    },
    "quantity": {
      "type": "number",
      "default": 1,
      "description": "Quantity"
    },
    "description": {
      "type": "string",
      "description": "Optional notes or details about this cart item",
      "maxLength": 1000
    }
  },
  "required": [
    "product_id"
  ]
}