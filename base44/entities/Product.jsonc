{
  "name": "Product",
  "type": "object",
  "rls": {
    "create": false,
    "read": true,
    "update": false,
    "delete": true
  },
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "price": {
      "type": "number",
      "description": "Product price"
    },
    "profit": {
      "type": "number",
      "description": "Profit per unit (optional, used for revenue tracking)"
    },
    "category": {
      "type": "string",
      "enum": [
        "electronics",
        "electronics_phones",
        "electronics_laptops",
        "electronics_earphones",
        "electronics_tablets",
        "electronics_accessories",
        "clothing",
        "clothing_mens",
        "clothing_womens",
        "clothing_kids",
        "accessories",
        "sports",
        "sports_fitness",
        "sports_outdoor",
        "phones",
        "shoes",
        "shoes_mens",
        "shoes_womens",
        "shoes_kids",
        "shoes_sport"
      ],
      "description": "Product category or subcategory"
    },
    "tags": {
      "type": "string",
      "description": "Comma-separated tags/keywords"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of image URLs"
    },
    "sizes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Available sizes/options"
    },
    "rating": {
      "type": "number",
      "description": "Average rating 0-5"
    },
    "stock": {
      "type": "number",
      "description": "Stock quantity"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "published": {
      "type": "boolean",
      "default": false,
      "description": "Whether the product is visible to customers. Unpublished = draft."
    },
    "trendingScore": {
      "type": "number",
      "default": 0,
      "description": "Computed trending score with time decay"
    },
    "totalPurchases": {
      "type": "number",
      "default": 0
    },
    "totalViews": {
      "type": "number",
      "default": 0
    },
    "totalWishlists": {
      "type": "number",
      "default": 0
    },
    "lastScoreUpdatedAt": {
      "type": "string",
      "description": "ISO timestamp of last score calculation"
    }
  },
  "required": [
    "name",
    "price",
    "category"
  ]
}