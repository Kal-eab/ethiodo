{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "phone": {
      "type": "string",
      "description": "Ethiopian phone number e.g. +251 9XX XXX XXX"
    },
    "region": {
      "type": "string",
      "description": "Ethiopian region"
    },
    "city": {
      "type": "string",
      "description": "City or sub-city"
    },
    "specific_address": {
      "type": "string",
      "description": "Specific address / landmark"
    },
    "profile_complete": {
      "type": "boolean",
      "default": false,
      "description": "Whether user has completed delivery info"
    }
  },
  "required": []
}