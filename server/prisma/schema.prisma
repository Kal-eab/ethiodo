generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String   @id @default(cuid())
  email                  String   @unique
  passwordHash           String
  fullName               String?
  role                   String   @default("user")
  phone                  String?
  region                 String?
  city                   String?
  specificAddress        String?
  profileComplete        Boolean  @default(false)
  notificationPermission String?
  isVerified             Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// Generic JSON-backed entities — mirrors the flexible schema Base44 used.
// `data` holds all entity-specific fields; RLS is enforced in application code
// (see server/src/entityConfig.js) rather than at the database layer.
model CartItem {
  id             String   @id @default(cuid())
  data           Json
  createdById    String?
  createdByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

