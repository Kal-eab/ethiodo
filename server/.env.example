# Postgres connection string (Render Postgres gives you this in the dashboard)
DATABASE_URL="postgresql://user:password@host:5432/ethiodo?schema=public"

# Long random string — used to sign login tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me"

# Comma-free single origin (or "*" for dev) — your deployed frontend URL
CORS_ORIGIN="https://your-frontend.onrender.com"

# Cloudflare R2 (S3-compatible object storage) for product/review photo
# uploads. Render's web service disk is ephemeral, so files must live here
# instead of on local disk. Create a bucket at https://dash.cloudflare.com
# -> R2, then an API token scoped to it, and either enable the bucket's
# public r2.dev URL or attach a custom domain for R2_PUBLIC_URL.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Claude API key for the admin "Review Insights AI" chat (server/src/routes/agents.js)
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-opus-4-8"

# Optional: Google Analytics 4 (admin Conversion Rates page). Leave unset to
# disable the feature gracefully instead of crashing.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
GA4_PROPERTY_ID=""

# Optional: Slack bot token, only needed if you wire up Slack notifications.
SLACK_BOT_TOKEN=""

PORT=3001
