# Postgres connection string (Render Postgres gives you this in the dashboard)
DATABASE_URL="postgresql://user:password@host:5432/ethiodo?schema=public"

# Long random string — used to sign login tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me"

# Comma-free single origin (or "*" for dev) — your deployed frontend URL
CORS_ORIGIN="https://your-frontend.onrender.com"

# Used to build absolute URLs for uploaded files. Leave unset to auto-derive
# from the incoming request (fine for a single Render web service).
PUBLIC_BASE_URL=""

# Claude API key for the admin "Review Insights AI" chat (server/src/routes/agents.js)
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-opus-4-8"

# Optional: Google Analytics 4 (admin Conversion Rates page). Leave unset to
# disable the feature gracefully instead of crashing.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
GA4_PROPERTY_ID=""

# Optional: Slack bot token, only needed if you wire up Slack notifications.
SLACK_BOT_TOKEN=""

PORT=3001
